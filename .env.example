# Sage — Submission Appetite & Grounded Evaluation agent
# Copy this file to `.env` and fill in your real values.
#
# Sage does NOT auto-load `.env` yet. To pick it up, start uvicorn with:
#
#   uvicorn sage.server:app --port 8004 --env-file .env --reload
#
# (Or ask me to add python-dotenv so it loads automatically.)

# ---------------------------------------------------------------------------
# LLM mode — controls whether Sage calls a real LLM or uses canned reasoning.
#   mock    — return MOCK_REASONING fixtures; ChromaDB retrieval still runs.
#             No API key required. Default.
#   real    — call the LLM with the retrieved appetite-memo passages.
#   hybrid  — same as `real` (kept for symmetry with the spec).
# ---------------------------------------------------------------------------
SAGE_LLM_MODE=mock

# ---------------------------------------------------------------------------
# LLM provider — used only when SAGE_LLM_MODE != mock.
#   openai     — gpt-4o, temperature 0.0
#   anthropic  — claude-sonnet-4-20250514, temperature 0.0
# Default: openai.
# ---------------------------------------------------------------------------
SAGE_LLM_PROVIDER=openai

# ---------------------------------------------------------------------------
# API keys — only the one matching SAGE_LLM_PROVIDER is required, and only
# in real/hybrid mode. If the call fails for any reason (missing key,
# network error, malformed JSON) Sage silently falls back to mock.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-me
# ANTHROPIC_API_KEY=sk-ant-replace-me
